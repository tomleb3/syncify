# ─────────────────────────────────────────────
# Syncify configuration template
# Copy this to syncify.config.yml and fill in your values.
# syncify.config.yml is in .gitignore — your config stays private.
# ─────────────────────────────────────────────

# Your Spotify user ID.
# How to find it: open Spotify → Your Profile → "..." → Share → Copy link.
# The ID is the segment after /user/ in the URL.
user_id: "your_user_id_here"

# Name of the playlist Syncify will create (or update if it already exists).
target_playlist: "Syncified"

# Playlists to merge into the target playlist.
# Names are case-sensitive. Leave empty to sync ALL your playlists.
source_playlists:
  - "Playlist A"
  - "Playlist B"

# Set to true to include playlists you follow but don't own.
include_external: false

# Optional: Telegram notifications on sync success/failure.
# Leave empty if you don't use Telegram.
telegram:
  chat_id: ""

# Optional: GitHub integration — lets the Telegram bot push playlist
# changes directly to GitHub Variables so the next cron run picks them up.
# Set GITHUB_TOKEN in your environment (a PAT with repo Actions Variables write access).
github:
  repo: ""  # e.g. "yourusername/syncify"
